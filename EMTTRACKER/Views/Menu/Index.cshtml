@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Menu - EMTTracker</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/menu.css" />
    <link rel="stylesheet" href="~/css/incidencias.css" />
</head>
<body>
    <div class="menu-header">
        <h1 class="text-light">
            Bienvenido a <span class="text-info">EMTTRACKER</span>
        </h1>
        <h4 class="text-light">¿Qué desea hoy?</h4>
    </div>

    <div class="menu-options">
        <a asp-controller="Emt" asp-action="Index" style="text-decoration: none; color: inherit; display: block;">
            <div class="menu-option">
                <div class="menu-circle">
                    <img src="~/images/emtLogo.png" alt="Buses EMT" />
                </div>
                <div class="menu-label">Buses EMT</div>
            </div>
        </a>

        <a asp-controller="Interurbano" asp-action="Index" style="text-decoration: none; color: inherit; display: block;">
            <div class="menu-option">
                <div class="menu-circle">
                    <img src="~/images/interurbano.png" alt="Interurbanos" />
                </div>
                <div class="menu-label">Interurbanos</div>
            </div>
        </a>

        <a asp-controller="Cercanias" asp-action="Index" style="text-decoration: none; color: inherit; display: block;">
            <div class="menu-option">
                <div class="menu-circle">
                    <img src="~/images/cercaniasRenfe.png" alt="Cercanías" />
                </div>
                <div class="menu-label">Cercanías</div>
            </div>
        </a>
    </div>

    <div id="panelIncidencias" class="fixed-bottom p-3" style="z-index: 1050; display: none;">
        <div class="container">
            <div class="alert alert-warning alert-dismissible fade show shadow-lg" role="alert">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <strong>⚠️ INCIDENCIAS ACTIVAS</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <div id="listaIncidencias" class="incidencias-panel">
                </div>
            </div>
        </div>
    </div>

    <div class="menu-footer">
        <h4 class="text-light">Proyecto realizado por Marcos Pedroche Pérez</h4>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            console.log("Cargando incidencias...");
            
            fetch('/Incidencias/GetIncidenciasJson')
                .then(response => {
                    console.log("Response status:", response.status);
                    if (!response.ok) {
                        throw new Error('Error en la respuesta: ' + response.status);
                    }
                    return response.json();
                })
                .then(data => {
                    console.log("Incidencias recibidas:", data);
                    
                    if (data && data.length > 0) {
                        const panel = document.getElementById("panelIncidencias");
                        const lista = document.getElementById("listaIncidencias");

                        let html = '';
                        data.forEach(incidencia => {
                            html += `
                                <div class="incidencia-item">
                                    <div class="incidencia-titulo">📢 ${incidencia.titulo}</div>
                                    <div class="incidencia-mensaje">${incidencia.mensaje}</div>
                                </div>
                            `;
                        });

                        lista.innerHTML = html;
                        panel.style.display = "block";
                    } else {
                        console.log("No hay incidencias activas");
                    }
                })
                .catch(error => {
                    console.error("Error al cargar incidencias:", error);
                });
        });
    </script>
</body>
</html>