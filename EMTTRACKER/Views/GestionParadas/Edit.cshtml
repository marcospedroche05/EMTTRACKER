@model Parada
@{
    ViewData["COLORLAYOUT"] = "#2a5298";
    bool esCercanias = !Model.Codigo.HasValue;
}

<div class="p-4 border-bottom border-1 border-primary d-flex w-100 align-items-center">
    <div>
        <h2 class="mb-0 text-primary">Editar Parada</h2>
    </div>
</div>

<div class="p-4 d-flex justify-content-center">
    <div class="card shadow-sm border-primary w-100" style="max-width: 500px;">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post" id="formParada">
                <input type="hidden" name="idparada" value="@Model.IdParada" />
                
                <div class="mb-4 bg-light p-3 rounded border">
                    <div class="form-check form-switch d-flex align-items-center mb-0">
                        <input class="form-check-input mt-0 me-3" type="checkbox" role="switch" id="switchCercanias" 
                               @(esCercanias ? "checked" : "") style="width: 2.5em; height: 1.25em;">
                        <label class="form-check-label fw-bold text-dark" for="switchCercanias">
                            Esta parada es de Cercanías
                        </label>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-primary">Nombre de la Parada</label>
                    <input type="text" name="nombre" class="form-control" value="@Model.Nombre" required />
                </div>

                <div class="mb-3" id="containerCodigo" style="opacity: @(esCercanias ? "0.5" : "1");">
                    <label class="form-label fw-bold text-primary">Código</label>
                    <input type="number" name="codigo" id="inputCodigo" class="form-control" 
                           value="@Model.Codigo" @(esCercanias ? "disabled" : "required") />
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary text-light">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const switchCercanias = document.getElementById("switchCercanias");
        const containerCodigo = document.getElementById("containerCodigo");
        const inputCodigo = document.getElementById("inputCodigo");

        switchCercanias.addEventListener("change", function () {
            if (this.checked) {
                // Es de cercanías
                inputCodigo.disabled = true;
                inputCodigo.removeAttribute("required");
                inputCodigo.value = "";
                containerCodigo.style.opacity = "0.5";
            } else {
                // Es normal
                inputCodigo.disabled = false;
                inputCodigo.setAttribute("required", "required");
                containerCodigo.style.opacity = "1";
            }
        });
    });
</script>
